  "keyFeatures": [
    "Multi-provider support (WhatsApp, Telegram, Email, Facebook, Instagram)",
    "Flow-based conversation builder with addKeyword and addAnswer",
    "Multiple database adapters (MongoDB, MySQL, PostgreSQL, JSON, Memory)",
    "State management (global and per-conversation)",
    "Queue system for concurrent message handling",
    "Event-driven architecture with custom events",
    "Media handling (images, videos, audio, documents)",
    "HTTP endpoints for external integrations",
    "Dialogflow integration for NLU",
    "CLI for quick project scaffolding",
    "Blacklist management",
    "Idle state detection",
    "TypeScript support"
